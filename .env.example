# Telegram API (get at https://my.telegram.org)
API_ID=12345678
API_HASH=your_api_hash

# Bot token from @BotFather
BOT_TOKEN=your_bot_token

# Gemini API key
GEMINI_KEY=your_gemini_key

# Your personal Telegram chat_id (owner, auto-added to subscribers)
OWNER_CHAT_ID=123456789

# Final digest send time (24h format, based on container's TZ — see TZ in docker run)
SEND_HOUR=21
SEND_MINUTE=0
COLLECT_MINUTES_BEFORE=10
